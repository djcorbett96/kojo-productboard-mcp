# ProductBoard API Token
# Get your token from: https://www.productboard.com/integrations/notes-api/
# Copy this file to .env and replace with your actual token
PRODUCTBOARD_API_TOKEN=your-token-here

# Default component ID for new triage features
# Find your component IDs via the search_features or Productboard UI
PRODUCTBOARD_TRIAGE_COMPONENT_ID=

# Default feature status ID (e.g., "New idea" status)
# Use GET /feature-statuses with X-Version: 1 to find status IDs
PRODUCTBOARD_DEFAULT_STATUS_ID=
